datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model RequestLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  model        String
  prompt       String
  response     String
  tokensIn     Int
  tokensOut    Int
  cost         Float
  latencyMs    Int
  cacheHit     Boolean  @default(false)
  provider     String   // "openai" or "anthropic"
}